# Google OAuth Web Client ID. Must match backend GOOGLE_CLIENT_ID.
VITE_GOOGLE_CLIENT_ID=your-google-oauth-web-client-id.apps.googleusercontent.com

# Dev-auth: баннер «Войти как Dev» на странице логина
# При yarn dev достаточно frontend/.env.development (коммитится)
VITE_DEV_AUTH_STUB=true

# Разрешить dev-auth в production-сборке (ТОЛЬКО для локального Docker test stack).
# ⚠️ ОПАСНО в реальном prod: вместе с VITE_DEV_AUTH_STUB=true это включает баннер
# «Войти как Dev» и обход Google-логина в собранном бандле. В prod держите
# закомментированным / =false. Раскомментируйте осознанно только для test-стека.
# VITE_DEV_AUTH_ALLOW_BUILD=true

# Supabase — для prod; при dev-auth можно оставить placeholder
VITE_SUPABASE_URL=https://placeholder.supabase.co
VITE_SUPABASE_ANON_KEY=placeholder-key

# Dev-auth: баннер «Войти как Dev» на странице логина
VITE_DEV_AUTH_STUB=true

# Разрешить dev-auth в production-сборке (Docker test stack)
VITE_DEV_AUTH_ALLOW_BUILD=true

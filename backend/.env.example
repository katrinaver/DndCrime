# === Режим быстрого тестирования (dev-auth + in-memory store) ===
# Скопируйте backend/.env.development.example → .env для локальной разработки
DEV_AUTH_ENABLED=true

# Supabase JWT — не нужен при DEV_AUTH_ENABLED=true; для prod укажите секрет
SUPABASE_JWT_SECRET=

PORT=8080
ALLOWED_ORIGINS=http://localhost:5173
